rule metadata:
    message: "extracting metadata from tree sequence" 
    input:
        ts = "../control/ctrl/trees/sim_{run}.trees"
    output:
        metadata = "metadata/{run}.tsv" 
    run:
        get_metadata(input.ts, output.metadata) 


