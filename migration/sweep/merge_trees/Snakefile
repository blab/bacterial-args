rule score_sim: 
    message: "scoring simulated args"
    input:
        loc_file = "../control/ctrl/locations/success/simulated/sim_{run}.csv",
        res_file = "out/sim_{run}/sim_{run}.states.tsv",
    output:
        outfile = "scores/sim_{run}.csv"
    run:
        score_sim(input.loc_file, input.res_file)

rule score_inf:
    message: "scoring inferred args"
    input:
        loc_file_sim = "../control/ctrl/locations/success/simulated/sim_{run}.csv",
        loc_file_inf = "../control/ctrl/locations/success/inferred/inf_{run}.csv",
        res_file = "out/inf_{run}/inf_{run}.states.tsv",
    output:
        outfile = "scores/inf_{run}.csv"
    run:
        score_inf(input.loc_file_sim, input.loc_file_inf, input.res_file)

rule score_ctrl: 
    message: "scoring inferred trees"
    input:
        loc_file_sim = "../control/ctrl/locations/success/simulated/sim_{run}.csv",
        loc_file_ctrl = "../control/ctrl/locations/success/control/control_{run}.csv",
    output:
        outfile = "scores/control_{run}.csv"
    run:
        score_ctrl(input.loc_file_sim, input.loc_file_ctrl)